# Токен бота, полученный от @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# ID администраторов через запятую (можно узнать через @userinfobot)
ADMIN_IDS=123456789,987654321

# Строка подключения к БД (по умолчанию SQLite)
DB_URL=sqlite+aiosqlite:///nail_bot.db

# Фото для приветственного сообщения /start (прямая ссылка на картинку или file_id).
# Можно оставить пустым - тогда сообщение будет отправлено без фото.
WELCOME_PHOTO_URL=

# Фото для сообщения со списком услуг и цен. Можно оставить пустым.
SERVICES_PHOTO_URL=
